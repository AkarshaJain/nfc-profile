# Used at build time for Open Graph / JSON-LD (set in GitHub Actions automatically).
# Local dev (optional):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Only if the site is served under a subpath (project Pages: /repo-name).
# Leave unset for username.github.io root site or local dev without base path.
# NEXT_PUBLIC_BASE_PATH=/your-repo-name
